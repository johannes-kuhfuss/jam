proxmox_endpoint  = "https://pve.example.lan:8006/api2/json"
proxmox_api_token = "opentofu@pve!jam=replace-with-token-secret"
proxmox_insecure  = true

proxmox_node_name = "pve"
template_vm_id    = 9000
datastore_id      = "local-lvm"

network_bridge = "vmbr0"
vlan_id        = null

cluster_name       = "jam-lab"
talos_version      = "v1.13.4"
# Must be supported by the selected Talos version.
# Check the Talos release notes/support matrix before changing.
kubernetes_version = "v1.36.1"

talos_node_count           = 1
talos_node_name_prefix     = "jam-talos"
talos_node_vm_id_start     = 301
talos_node_cpu_cores       = 4
talos_node_memory_mb       = 8192
talos_node_disk_size_gb    = 40
longhorn_data_disk_size_gb = 40
talos_qemu_agent_enabled   = false
talos_install_disk         = "/dev/sda"
# Longhorn requires the Talos image to include siderolabs/iscsi-tools and
# siderolabs/util-linux-tools. Leave this unset when the Proxmox template
# already includes those extensions; otherwise point at a matching Image
# Factory installer.
# talos_installer_image = "factory.talos.dev/installer/<schematic-id>:v1.12.0"
longhorn_data_disk_selector = "!system_disk"
talos_network_interface    = "eth0"

talos_node_ipv4_addresses = [
  "192.168.1.50",
]

# Optional but recommended. Use these MACs for DHCP reservations so OpenTofu can
# reach the Talos maintenance API before the final static config is applied.
talos_node_mac_addresses = [
  "02:00:00:00:50:01",
]

# For a 3-node redundant cluster, use:
# talos_node_count       = 3
# talos_node_vm_id_start = 301
# talos_node_ipv4_addresses = [
#   "192.168.1.50",
#   "192.168.1.51",
#   "192.168.1.52",
# ]
# talos_node_mac_addresses = [
#   "02:00:00:00:50:01",
#   "02:00:00:00:50:02",
#   "02:00:00:00:50:03",
# ]

ipv4_prefix_length = 24
ipv4_gateway       = "192.168.1.1"
dns_domain         = "home.arpa"
dns_servers        = ["192.168.1.1"]

# Use a free IP in the same L2 subnet that kube-vip can advertise.
api_virtual_ip = "192.168.1.60"
